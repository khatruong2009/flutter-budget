            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Run Script"
               scriptText = "# Type a script or drag a script file from your workspace to insert its path.&#10;cd &quot;$SRCROOT/..&quot;&#10;&#10;CURRENT=$(grep &quot;^version:&quot; pubspec.yaml | sed &apos;s/version: //&apos;)&#10;VERSION_NAME=$(echo &quot;$CURRENT&quot; | cut -d&apos;+&apos; -f1)&#10;BUILD_NUM=$(echo &quot;$CURRENT&quot; | cut -d&apos;+&apos; -f2)&#10;&#10;# If no build number exists, start at 1&#10;if [ -z &quot;$BUILD_NUM&quot; ] || [ &quot;$BUILD_NUM&quot; = &quot;$CURRENT&quot; ]; then&#10;  NEW_BUILD=1&#10;else&#10;  NEW_BUILD=$((BUILD_NUM + 1))&#10;fi&#10;&#10;sed -i &apos;&apos; &quot;s/^version: .*/version: ${VERSION_NAME}+${NEW_BUILD}/&quot; pubspec.yaml&#10;">
